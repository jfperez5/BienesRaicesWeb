---
import { propiedades } from "../../data/propiedades";
import CarruselPropiedades from "../CarruselPropiedades.astro";

const carruselPropiedades = [...propiedades, ...propiedades];
---

<section class="pt-32">
    <div class="text-center mb-16">
      <h3 class="text-[#143549] text-6xl font-semibold">
        Nuestras <span class="font-light text-white">Propiedades</span>
      </h3>
    </div>
    <article class="overflow-hidden">
      <div class="flex animate-scroll">
        {
          carruselPropiedades.map((propiedad) => (
            <CarruselPropiedades propiedad={propiedad} />
          ))
        }
      </div>
    </article>
  </section>